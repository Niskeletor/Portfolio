---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const studies = (await getCollection('case-studies') || []).filter(
    e => e.id.startsWith('es/') && !e.data.draft
  );
  return studies.map(study => ({
    params: { slug: study.id.replace(/^es\//, '') },
    props: study,
  }));
}

const study = Astro.props;
const { Content } = await render(study);
const slug = study.id.replace(/^es\//, '');
---
<BaseLayout title={`${study.data.title} — Pablo Nistal`} description={study.data.description} lang="es" altPath={`/case-studies/${slug}/`}>
  <article class="min-h-screen pt-24 pb-16 px-6">
    <div class="max-w-3xl mx-auto">
      <a href="/es/#projects" class="text-sm text-muted-foreground hover:text-white transition-colors mb-8 block">← Volver a casos de estudio</a>
      <p class="text-sm text-muted-foreground mb-2">
        {study.data.pubDate.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>
      <h1 class="text-4xl font-bold text-white mb-4">{study.data.title}</h1>
      <p class="text-lg mb-6" style="color: var(--color-muted-foreground)">{study.data.description}</p>
      {study.data.metrics.length > 0 && (
        <div class="flex flex-wrap gap-6 mb-8 p-6 card">
          {study.data.metrics.map((m: { value: string; label: string }) => (
            <div class="text-center">
              <div class="text-2xl font-bold gradient-text">{m.value}</div>
              <div class="text-xs text-muted-foreground mt-1">{m.label}</div>
            </div>
          ))}
        </div>
      )}
      <div class="flex flex-wrap gap-2 mb-10">
        {study.data.tags.map((tag: string) => (
          <span class="text-xs px-2 py-1 rounded-full bg-primary/10 text-primary">{tag}</span>
        ))}
      </div>
      <div class="prose prose-invert max-w-none">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
